# Server
HOST=0.0.0.0
PORT=8082

# Upstream (OpenAI-compatible API)
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-upstream-api-key

# Relay auth (API key for clients)
