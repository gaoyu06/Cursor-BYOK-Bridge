# Server
HOST=0.0.0.0
PORT=8082

# Upstream endpoint (set full endpoint URL, not just base domain)
UPSTREAM_BASE_URL=https://api.openai.com/v1/responses
UPSTREAM_API_KEY=sk-your-upstream-api-key
# Upstream auth header mode: authorization | x-api-key
UPSTREAM_API_KEY_HEADER=authorization

# Relay auth (API key for clients)
RELAY_API_KEY=change-me-to-a-long-random-string

# Logging & Dashboard
LOG_BODY_LIMIT=20000
LOG_STORE_LIMIT=200
DASHBOARD_ENABLED=true
DASHBOARD_TITLE=BYOK Relay Logs
